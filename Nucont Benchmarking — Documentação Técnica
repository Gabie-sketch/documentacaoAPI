    id_setor = Column(Integer, primary_key=True, autoincrement=True)
    id_edicao = Column(String, ForeignKey("edicoes.id_edicao"), nullable=False)
    nome_setor = Column(String, nullable=False)
    slug = Column(String, nullable=False)
    empresas_analisadas = Column(Integer, nullable=True)
    indicador_1_nome = Column(String, nullable=True)
